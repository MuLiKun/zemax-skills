# ---- Python 虚拟环境（体积大、含本机绝对路径，绝不入库）----
.venv/
venv/
env/

# ---- Python 缓存与编译产物 ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# ---- 运行输出与中间产物 ----
output/
*.log

# ---- Zemax 运行中间/结果文件 ----
*.ZTD
*.TSC
*.MF
*_tol.zmx

# ---- Excel 临时锁文件 ----
~$*.xlsx

# ---- IDE / 系统 ----
.idea/
*.swp
Thumbs.db
Desktop.ini
.DS_Store
